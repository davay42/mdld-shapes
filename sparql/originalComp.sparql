# List all SHACL Constraint Components with their parameters
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?component ?label ?comment ?parameter ?parameterPath ?optional ?datatype ?nodeKind
WHERE {
  ?component a sh:ConstraintComponent .
  OPTIONAL { ?component rdfs:label ?label }
  OPTIONAL { ?component rdfs:comment ?comment }
  OPTIONAL { 
    ?component sh:parameter ?parameter .
    OPTIONAL { ?parameter sh:path ?parameterPath }
    OPTIONAL { ?parameter sh:optional ?optional }
    OPTIONAL { ?parameter sh:datatype ?datatype }
    OPTIONAL { ?parameter sh:nodeKind ?nodeKind }
  }
}
ORDER BY ?component ?parameter
